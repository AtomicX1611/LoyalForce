# ==============================================================================
# LoyalForce Backend — Environment Variable Blueprint
# ==============================================================================
# Copy this file to `.env` and fill in REAL values before running the server.
# NEVER commit the real .env to version control.
# The application will CRASH on startup if any required variable is missing.
# ==============================================================================

# --- Server ---
PORT=8000
HOST=0.0.0.0

# --- CORS (comma-separated, no trailing slash) ---
ALLOWED_CORS_ORIGINS=http://localhost:5173,https://your-deployed-frontend.vercel.app

# --- MongoDB ---
# Replace <username>, <password>, and <cluster> with your Atlas credentials.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/loyalty_analytics?retryWrites=true&w=majority

# --- JWT Signing ---
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=replace_with_a_long_cryptographically_secure_random_string
JWT_ALGORITHM=HS256
# Token expiry in minutes
JWT_EXPIRE_MINUTES=480

# --- ML Model Artifact ---
# Relative to the backend/ directory. Populated in Phase 3.
MODEL_PATH=./ml_artifacts/loyalty_model.joblib

# --- Tenant Bootstrapping (used by seed_db.py) ---
SEED_TENANT_ID=northern_lights_air
SEED_COMPANY_NAME=Northern Lights Air
